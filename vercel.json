{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "api/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/$1" }
  ],
  "crons": [
    {
      "path": "/api/morning-digest",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/health",
      "schedule": "*/10 * * * *"
    }
  ]
}
